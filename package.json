{
  "name": "stormic",
  "version": "1.9.0",
  "description": "Minimal P2P voice and chat app",
  "main": "src/main.js",
  "scripts": {
    "prestart": "node scripts/generate-env.js",
    "start": "electron .",
    "bump": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version",
    "build:win": "node scripts/generate-env.js && electron-builder --win",
    "build:mac": "node scripts/generate-env.js && electron-builder --mac",
    "build:linux": "node scripts/generate-env.js && electron-builder --linux",
    "build:all": "node scripts/generate-env.js && electron-builder --win --mac --linux",
    "release:win": "npm version patch --no-git-tag-version && node scripts/generate-env.js && electron-builder --win --publish always",
    "release:mac": "npm version patch --no-git-tag-version && node scripts/generate-env.js && electron-builder --mac --publish always",
    "release:all": "npm version patch --no-git-tag-version && node scripts/generate-env.js && electron-builder --win --mac --linux --publish always"
  },
  "build": {
    "appId": "com.stormic.app",
    "productName": "StorMIC",
    "copyright": "StorMIC",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "tr_TR",
        "en_US"
      ],
      "shortcutName": "StorMIC",
      "uninstallDisplayName": "StorMIC",
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "MMetehan",
      "repo": "StorMIC"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "simple-peer": "^9.11.1"
  }
}
