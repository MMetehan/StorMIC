# Copy this file to .env and fill in your signaling server URL.
# .env is gitignored — this URL will never appear in the repository.
#
# The URL is baked into the app at build time (make win / make mac / make linux).
# For local development (make dev) the value is also used; if left empty the
# user must configure the server URL manually inside the app's Settings panel.
#
# See server/README.md for instructions on running your own signaling server.

STORMIC_SIGNAL_URL=wss://your-signaling-server.example.com
